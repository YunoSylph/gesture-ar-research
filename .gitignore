.DS_Store
.venv/
.venv-gesture-ar/
.vs/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.sixth/
# Ignore generated artifacts, but keep the small trained model files in git so the
# repo is self-contained for inference/export on another machine (e.g. the M1 Mac).
artifacts/*
!artifacts/models/
artifacts/models/*
!artifacts/models/*.pkl
docs/generated/
data/raw/
data/processed/
# Local rear-camera capture videos (large personal .MOV clips) — never commit.
local_vids/
# Raw IPN Hand download (~28 GB) — never commit; lives only on the training box.
IPN_Hand/
node_modules/
# Swift Package Manager build output / metadata (ios_demo).
.build/
.swiftpm/
# iOS app: project generated by XcodeGen (project.yml is the source of truth) and
# the derived model copies (originals live in models/mediapipe/ and artifacts/export/).
ios_demo/GestureAR/GestureAR.xcodeproj/
ios_demo/GestureAR/hand_landmarker.task
dist/
demo/ar_interaction_app/dist/
npm-debug.log*
launcher_test*.log
*.onnx
*.mlpackage/
